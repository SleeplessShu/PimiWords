<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:backgroundTint="?attr/colorPrimary">

    <Button
        android:id="@+id/b_true"
        android:layout_width="180dp"
        android:layout_height="90dp"
        android:textColor="?attr/colorOnPrimary"
        android:backgroundTint="@color/item_default"
        android:text="true"
        android:layout_marginBottom="90dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/b_false"/>

    <Button
        android:id="@+id/b_false"
        android:layout_width="180dp"
        android:layout_height="90dp"
        android:textColor="?attr/colorOnPrimary"
        android:backgroundTint="@color/item_default"
        android:text="false"
        android:layout_marginBottom="90dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/b_true"/>

    <TextView
        android:id="@+id/t_word"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="word"
        android:textSize="50dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="180dp"/>

    <TextView
        android:id="@+id/t_translate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="translate"
        android:textSize="50dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/t_word"
        android:layout_marginTop="20dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>