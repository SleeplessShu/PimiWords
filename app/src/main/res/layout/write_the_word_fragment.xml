<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Слово-подсказка сверху -->
    <TextView
        android:id="@+id/tvPrompt"
        android:layout_width="0dp"
        android:layout_height="110dp"
        android:background="@drawable/bg_panoramic_view_default_r_16"
        android:gravity="center"
        android:textColor="@color/dark_text_default"
        android:textSize="36sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Панорамный вид" />

    <TextView
        android:id="@+id/tvInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingTop="20dp"
        android:textColor="@color/white"
        android:textSize="32sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvPrompt"
        tools:text="_ _ _ _ _ _ _\n_ _ _ _ _ _ _ _ _ _" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLetters"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toTopOf="@id/llButtons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvInput" />

    <LinearLayout
        android:id="@+id/llButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/btnCheck"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnClear"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_rounded_12"
            android:backgroundTint="@color/btn_bg_tint"
            android:contentDescription="@string/btn_clear_word"
            android:src="@drawable/delete_word"
            app:tint="@color/btn_icon_tint" />

        <Button
            android:id="@+id/btnSkip"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_rounded_12"
            android:text="@string/btn_skip"
            android:textColor="@color/white"
            android:layout_marginHorizontal="12dp"
            app:backgroundTint="@color/btn_bg_tint"
            android:contentDescription="@string/btn_skip"
            android:textSize="20sp" />

        <ImageButton
            android:id="@+id/btnClearLetter"
            android:layout_width="48dp"
            android:layout_height="48dp"

            android:background="@drawable/bg_button_rounded_12"
            android:backgroundTint="@color/btn_bg_tint"
            android:contentDescription="@string/btn_clear_letter"
            android:src="@drawable/delete_letter"
            app:tint="@color/btn_icon_tint" />
    </LinearLayout>

    <Button
        android:id="@+id/btnCheck"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="@string/btn_check"
        app:backgroundTint="@color/btn_bg_tint"
        android:text="@string/btn_check"
        android:textColor="@color/dark_text_used"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/correctAnswerRoot"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@color/background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvCorrectAnswer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="20dp"
            android:textSize="42sp"
            android:gravity="center"
            tools:text="twelve"
            android:textColor="@color/green_primary" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:contentDescription="@string/btn_continue"
            android:text="@string/btn_continue"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_rounded_12"
            android:textColor="@color/white"
            app:backgroundTint="@color/btn_bg_tint"
            android:layout_marginHorizontal="12dp"
            android:textSize="20sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>