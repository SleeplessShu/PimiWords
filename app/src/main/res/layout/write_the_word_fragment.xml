<!-- write_the_word_fragment.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="16dp">

    <TextView
        android:id="@+id/tvPrompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:height="110dp"
        android:background="@drawable/bg_panoramic_view_default_r_16"
        android:gravity="center"
        android:textColor="@color/dark_text_default"
        android:textSize="35sp"
        android:textStyle="bold"
        tools:text="Панорамный вид" />

    <TextView
        android:id="@+id/tvInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingTop="20dp"
        android:textColor="@android:color/white"
        android:textSize="32sp"
        tools:text="_ _ _ _ _ _ _\n_ _ _ _ _ _ _ _ _ _" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLetters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingHorizontal="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="80dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnClear"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_rounded_12"
            android:backgroundTint="@color/btn_bg_tint"
            android:contentDescription="@string/btn_clear_word"
            android:src="@drawable/delete_word"
            app:tint="@color/btn_icon_tint" />

        <Space
            android:layout_width="66dp"
            android:layout_height="0dp" />

        <ImageButton
            android:id="@+id/btnClearLetter"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_rounded_12"
            android:backgroundTint="@color/btn_bg_tint"
            android:contentDescription="@string/btn_clear_letter"
            android:src="@drawable/delete_letter"
            app:tint="@color/btn_icon_tint" />
    </LinearLayout>

    <Space
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btnCheck"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:contentDescription="@string/btn_check"
        android:text="Проверить"
        android:textColor="@color/dark_text_used"
        android:textSize="20sp" />
</LinearLayout>
