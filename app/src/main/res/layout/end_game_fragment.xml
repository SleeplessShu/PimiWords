<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_primary">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_a"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.50" />

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/animationBgView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="@id/baseBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/animation_bg_confeti" />

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/animationIdleView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toTopOf="@id/baseBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:lottie_autoPlay="false"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/animations_first_juggles" />


    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveWords"
        style="@style/Widget.Material3.Button"
        android:layout_width="40dp"
        android:layout_height="46dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:foreground="@drawable/ic_save_words"
        app:backgroundTint="@color/gray_02"
        app:cornerRadius="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:rippleColor="@color/white" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReportWords"
        style="@style/Widget.Material3.Button"
        android:layout_width="40dp"
        android:layout_height="46dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:foreground="@drawable/ic_report_word"
        app:backgroundTint="@color/gray_02"
        app:cornerRadius="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:rippleColor="@color/white" />

    <ImageView
        android:id="@+id/baseBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_language_panel_r24"
        android:backgroundTint="@color/gray_06"
        app:layout_constraintBottom_toTopOf="@id/bNewGame"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideline_a" />

    <TextView
        android:id="@+id/tvResult"
        style="@style/Text.H1.DisplayLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/murs_gothic_wide_dark"
        android:textSize="30sp"
        android:textColor="@color/white"
        app:layout_constraintEnd_toEndOf="@id/baseBackground"
        app:layout_constraintStart_toStartOf="@id/baseBackground"
        app:layout_constraintTop_toTopOf="@id/baseBackground"
        tools:text="@string/end_game_phrase_win" />

    <TextView
        android:id="@+id/tvPhrase"
        style="@style/Text.H3.HeadlineSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:textColor="@color/gray_03"
        app:layout_constraintEnd_toEndOf="@id/baseBackground"
        app:layout_constraintStart_toStartOf="@id/baseBackground"
        app:layout_constraintTop_toBottomOf="@id/tvResult"
        android:text="@string/eg_congrats" />

    <ImageView
        android:id="@+id/errorsBackground"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="14dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_end_game_r10"
        app:layout_constraintBottom_toBottomOf="@id/baseBackground"
        app:layout_constraintStart_toStartOf="@id/baseBackground"
        app:layout_constraintEnd_toStartOf="@id/scoreBackground" />

    <ImageView
        android:id="@+id/scoreBackground"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_end_game_r10"
        app:layout_constraintBottom_toBottomOf="@id/baseBackground"
        app:layout_constraintEnd_toStartOf="@id/wordsBackground"
        app:layout_constraintStart_toEndOf="@id/errorsBackground" />

    <ImageView
        android:id="@+id/wordsBackground"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginEnd="14dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_end_game_r10"
        app:layout_constraintBottom_toBottomOf="@id/baseBackground"
        app:layout_constraintEnd_toEndOf="@id/baseBackground"
        app:layout_constraintStart_toEndOf="@id/scoreBackground" />

    <TextView
        android:id="@+id/tvErrors"
        style="@style/Text.H3.HeadlineSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:layout_marginTop="8dp"
        tools:text="0"
        app:layout_constraintTop_toTopOf="@id/errorsBackground"
        app:layout_constraintStart_toStartOf="@id/errorsBackground"
        app:layout_constraintEnd_toEndOf="@id/errorsBackground" />

    <TextView
        android:id="@+id/tvErrorsDescription"
        style="@style/Text.T3.TextLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/gray_03"
        android:layout_marginTop="20dp"
        android:text="@string/eg_errors"
        app:layout_constraintTop_toTopOf="@id/tvErrors"
        app:layout_constraintStart_toStartOf="@id/errorsBackground"
        app:layout_constraintEnd_toEndOf="@id/errorsBackground" />

    <TextView
        android:id="@+id/tvScore"
        style="@style/Text.H3.HeadlineSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:layout_marginTop="8dp"
        tools:text="40"
        app:layout_constraintTop_toTopOf="@id/scoreBackground"
        app:layout_constraintStart_toStartOf="@id/scoreBackground"
        app:layout_constraintEnd_toEndOf="@id/scoreBackground" />

    <TextView
        android:id="@+id/tvScoreDescription"
        style="@style/Text.T3.TextLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/gray_03"
        android:layout_marginTop="20dp"
        android:text="@string/eg_points"
        app:layout_constraintTop_toTopOf="@id/tvScore"
        app:layout_constraintStart_toStartOf="@id/scoreBackground"
        app:layout_constraintEnd_toEndOf="@id/scoreBackground" />

    <TextView
        android:id="@+id/tvWords"
        style="@style/Text.H3.HeadlineSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:layout_marginTop="8dp"
        tools:text="40"
        app:layout_constraintTop_toTopOf="@id/wordsBackground"
        app:layout_constraintStart_toStartOf="@id/wordsBackground"
        app:layout_constraintEnd_toEndOf="@id/wordsBackground" />

    <TextView
        android:id="@+id/tvWordsDescription"
        style="@style/Text.T3.TextLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/gray_03"
        android:layout_marginTop="20dp"
        android:text="@string/eg_words"
        app:layout_constraintTop_toTopOf="@id/tvWords"
        app:layout_constraintStart_toStartOf="@id/wordsBackground"
        app:layout_constraintEnd_toEndOf="@id/wordsBackground" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/bNewGame"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:checkable="true"
        android:text="@string/button_new_game"
        android:textAllCaps="false"
        android:textColor="@color/gray_02"
        android:textSize="20sp"
        android:textStyle="bold"
        app:backgroundTint="@color/green_primary"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toTopOf="@id/bRestart"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:rippleColor="@color/white" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/bRestart"
        style="@style/Widget.Material3.Button"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="40dp"
        android:checkable="true"
        android:text="@string/button_restart_round"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:backgroundTint="@color/gray_02"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/bToSettings"
        app:layout_constraintStart_toStartOf="@id/bNewGame"
        app:rippleColor="@color/white" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/bToSettings"
        style="@style/Widget.Material3.Button"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="40dp"
        android:checkable="true"
        android:text="@string/button_to_settings"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:backgroundTint="@color/gray_02"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/bNewGame"
        app:layout_constraintStart_toEndOf="@id/bRestart"
        app:rippleColor="@color/white" />


</androidx.constraintlayout.widget.ConstraintLayout>