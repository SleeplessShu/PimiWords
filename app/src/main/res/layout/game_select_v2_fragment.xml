<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="@color/black_primary">

    <!-- Гайды -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/leftBorder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="20dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/rightBorder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="20dp" />

    <!-- язык -->
    <ImageView
        android:id="@+id/languageSelect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginVertical="20dp"
        app:layout_constraintEnd_toEndOf="@id/rightBorder"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/language_flag_spanish_l" />

    <!-- лого -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="@id/leftBorder"
        app:layout_constraintTop_toTopOf="@id/languageSelect"
        app:layout_constraintBottom_toBottomOf="@id/languageSelect"
        app:srcCompat="@drawable/logo" />






    <!-- заголовок -->
    <TextView
        android:id="@+id/gameSelect"
        style="@style/Header_01"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/select_game"
        app:layout_constraintStart_toStartOf="@id/leftBorder"
        app:layout_constraintEnd_toEndOf="@id/rightBorder"
        app:layout_constraintTop_toBottomOf="@id/languageSelect" />

    <!-- БОЛЬШАЯ КАРТОЧКА Matching The Words -->
    <com.sleeplessdog.matchthewords.gameSelect.controller.GameOptionViewLong
        android:id="@+id/match6"

        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="@id/leftBorder"
        app:layout_constraintEnd_toEndOf="@id/rightBorder"
        app:layout_constraintTop_toBottomOf="@id/gameSelect" />

    <!-- ПЕРВАЯ КАРТОЧКА ВО ВТОРОМ РЯДУ -->
    <com.sleeplessdog.matchthewords.gameSelect.controller.GameOptionViewShort
        android:id="@+id/trueOrFalse"

        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintStart_toStartOf="@id/leftBorder"
        app:layout_constraintEnd_toStartOf="@id/multiChoise"
        app:layout_constraintTop_toBottomOf="@id/match6" />

    <!-- ВТОРАЯ КАРТОЧКА ВО ВТОРОМ РЯДУ -->
    <com.sleeplessdog.matchthewords.gameSelect.controller.GameOptionViewShort
        android:id="@+id/multiChoise"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="4dp"
        app:layout_constraintStart_toEndOf="@id/trueOrFalse"
        app:layout_constraintEnd_toEndOf="@id/rightBorder"
        app:layout_constraintTop_toBottomOf="@id/match6" />

    <!-- НИЖНЯЯ ШИРОКАЯ КАРТОЧКА -->
    <com.sleeplessdog.matchthewords.gameSelect.controller.GameOptionViewLong
        android:id="@+id/writeTheWord"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="@id/leftBorder"
        app:layout_constraintEnd_toEndOf="@id/rightBorder"
        app:layout_constraintTop_toBottomOf="@id/multiChoise" />

    <ImageView
        android:id="@+id/languagesBackground"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/gameSelect"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:src="@color/opaque"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLanguages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="@drawable/bg_lang_panel"
        android:paddingTop="24dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/languageSelect" />


</androidx.constraintlayout.widget.ConstraintLayout>
