<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:layout_marginHorizontal="20dp">


    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/bOrigin"
        style="@style/Words_style"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/bg_card_default"
        app:layout_constraintEnd_toStartOf="@id/bTranslate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="умный" />


    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/bTranslate"
        style="@style/Words_style"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginStart="4dp"

        android:background="@drawable/bg_card_default"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/bOrigin"
        app:layout_constraintTop_toTopOf="@id/bOrigin"
        tools:text="intelligente" />

    <ImageView
        android:id="@+id/origin_pimi"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:elevation="8dp"
        android:src="@drawable/pimi_game_end_victory"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/bOrigin"
        app:layout_constraintEnd_toEndOf="@id/bOrigin"
        app:layout_constraintStart_toStartOf="@id/bOrigin"
        app:layout_constraintTop_toTopOf="@id/bOrigin" />

    <ImageView
        android:id="@+id/translation_pimi"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:elevation="8dp"
        android:src="@drawable/pimi_game_end_victory"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/bTranslate"
        app:layout_constraintEnd_toEndOf="@id/bTranslate"
        app:layout_constraintStart_toStartOf="@id/bTranslate"
        app:layout_constraintTop_toTopOf="@id/bTranslate" />
</androidx.constraintlayout.widget.ConstraintLayout>
