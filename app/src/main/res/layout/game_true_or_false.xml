<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="@color/black_primary">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/leftBorder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="20dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/rightBorder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="20dp" />

    <FrameLayout
        android:id="@+id/btnFalse"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/cardwards_default"
        android:foreground="@drawable/ripple_r12"
        android:layout_marginBottom="20dp"
        app:layout_constraintStart_toStartOf="@id/leftBorder"
        app:layout_constraintEnd_toStartOf="@id/btnTrue"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/icFalse"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@drawable/b_tof_no"
            app:tint="@color/red_primary"
            android:scaleType="centerInside"/>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/btnTrue"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="4dp"
        android:background="@drawable/cardwards_default"
        android:foreground="@drawable/ripple_r12"
        android:layout_marginBottom="20dp"
        app:layout_constraintStart_toEndOf="@+id/btnFalse"
        app:layout_constraintEnd_toEndOf="@id/rightBorder"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/icTrue"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:src="@drawable/b_tof_yes"
            app:tint="@color/green_primary"
            android:scaleType="centerInside"/>
    </FrameLayout>



    <FrameLayout
        android:id="@+id/cardHost"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
android:layout_marginBottom="100dp"
        android:paddingHorizontal="20dp"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- Верхняя (активная) карточка -->
        <include
            android:id="@+id/wordCardA"
            layout="@layout/view_tof_card"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_gravity="center" />

        <!-- Нижняя (следующая) карточка -->
        <include
            android:id="@+id/wordCardB"
            layout="@layout/view_tof_card"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:visibility="invisible" />

    </FrameLayout>


    <TextView
        android:id="@+id/result"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="136dp"
        android:text="@string/tof_correct"
        android:gravity="center"
        android:textColor="@color/dark_gray"
        android:letterSpacing="0.03"
        android:textSize="26sp"
        android:fontFamily="@font/murs_gothic_wide_dark"
        android:textFontWeight="800"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/leftBorder"
        app:layout_constraintEnd_toEndOf="@id/rightBorder"
        android:background="@drawable/bg_tof_card_r16"
        android:backgroundTint="@color/test"/>

</androidx.constraintlayout.widget.ConstraintLayout>