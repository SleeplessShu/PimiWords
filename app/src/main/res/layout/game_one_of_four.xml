<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:layout_marginTop="60dp"
        android:id="@+id/original"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:textColor="?attr/colorOnPrimary"
        android:gravity="center"
        android:textSize="50sp"
        android:text="ORIGINAL"/>

    <androidx.appcompat.widget.AppCompatButton
        android:layout_marginTop="200dp"
        android:id="@+id/b1"
        style="@style/Words_style"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginStart="@dimen/padding_small"
        android:textColor="?attr/colorOnPrimary"
        android:background="@drawable/word_background_default"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="умный" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/b2"
        style="@style/Words_style"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginEnd="@dimen/padding_small"
        android:background="@drawable/word_background_default"
        android:textColor="?attr/colorOnPrimary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/b1"
        tools:text="умный" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/multiChoise"
        android:layout_marginTop="20dp"
        style="@style/Words_style"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginStart="@dimen/padding_small"
        android:background="@drawable/word_background_default"
        android:textColor="?attr/colorOnPrimary"
        app:layout_constraintTop_toBottomOf="@id/b1"
        app:layout_constraintStart_toStartOf="parent"
        tools:text="умный" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/writeTheWord"
        style="@style/Words_style"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginEnd="@dimen/padding_small"
        android:background="@drawable/word_background_default"
        android:textColor="?attr/colorOnPrimary"
app:layout_constraintEnd_toEndOf="@id/original"
        app:layout_constraintTop_toTopOf="@id/multiChoise"
        tools:text="умный" />

</androidx.constraintlayout.widget.ConstraintLayout>