<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/original"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:text="ORIGINAL"
        android:textColor="@color/green_primary"
        android:textSize="50sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/b1" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/b1"
        style="@style/Words_style"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_card_default"
        android:textColor="@color/green_primary"
        app:layout_constraintEnd_toStartOf="@id/b2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/b3"
        tools:text="умный" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/b2"
        style="@style/Words_style"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_card_default"
        android:textColor="@color/green_primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/b1"
        app:layout_constraintTop_toTopOf="@id/b1"
        tools:text="умный" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/b3"
        style="@style/Words_style"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="60dp"
        android:background="@drawable/bg_card_default"
        android:textColor="@color/green_primary"
        app:layout_constraintEnd_toStartOf="@id/b4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:text="умный" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/b4"
        style="@style/Words_style"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_card_default"
        android:textColor="@color/green_primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/b3"
        app:layout_constraintTop_toTopOf="@id/b3"
        tools:text="умный" />

</androidx.constraintlayout.widget.ConstraintLayout>