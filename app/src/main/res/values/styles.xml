<?xml version="1.0" encoding="utf-8"?>

<resources>
    <style name="BottomNavTextActive" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">@font/murs_gothic_wide_dark</item>
    </style>

    <style name="BottomNavTextInactive" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">@font/murs_gothic_wide_dark</item>
    </style>

    <!--HEADERS-->
    <style name="Header_ver2" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textSize">@dimen/ts_22sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">@font/murs_gothic_wide_dark</item>
    </style>

    <!--WORDS-->
    <style name="Words_style">
        <item name="android:textSize">@dimen/ts_16sp</item>
        <item name="android:fontFamily">@font/open_sans_bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="singleLine">false</item>
        <item name="android:letterSpacing">0.00</item>
        <item name="cornerRadius">0dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:paddingHorizontal">@dimen/padding_small</item>
    </style>

    <!--START_GAME-->
    <style name="Stats">
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">@font/murs_gothic_wide_dark</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!--END_GAME-->
    <style name="EndGameButtonStyle" parent="Widget.MaterialComponents.Button">
        <!-- Размеры -->
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">64dp</item>

        <!-- Радиус и фон -->
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">@color/dark_gray</item>

        <!-- Текст -->
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">@font/murs_gothic_wide_dark</item>
        <item name="android:textSize">@dimen/ts_16sp</item>
        <item name="android:letterSpacing">0.00</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>

        <!-- Внешний отступ (если одинаков для всех кнопок) -->
        <item name="android:layout_marginHorizontal">20dp</item>
    </style>

    <!--SELECT_GAME-->
    <style name="Header_01">
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">@font/murs_gothic_wide_dark</item>
        <item name="android:textSize">26sp</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- FONTS -->
    <style name="Text.H1.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:fontFamily">@font/murs_gothic_wide_dark</item>
        <item name="android:textSize">62sp</item>
        <item name="android:lineHeight">62sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- H-2 Headline Large — 26/30 -->
    <style name="Text.H2.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/murs_gothic_wide_dark</item>
        <item name="android:textSize">26sp</item>
        <item name="android:lineHeight">30sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.H2.Simple" parent="">
        <item name="android:fontFamily">@font/murs_gothic_wide_dark</item>
        <item name="android:textSize">26sp</item>
        <item name="android:lineHeight">30sp</item>
        <item name="android:fontWeight">800</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- H-3 Headline Small — 20/24 -->
    <style name="Text.H3.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:fontFamily">@font/murs_gothic_wide_dark</item>
        <item name="android:textSize">20sp</item>
        <item name="android:lineHeight">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- ===== Titles / Body / Labels (Open Sans Bold) ===== -->

    <!-- T-1 Title Large — 24/30 -->
    <style name="Text.T1.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/open_sans_bold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:lineHeight">30sp</item>
    </style>

    <!-- T-2 Title Small — 20/24 -->
    <style name="Text.T2.TitleSmall" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">@font/open_sans_bold</item>
        <item name="android:textSize">20sp</item>
        <item name="android:lineHeight">24sp</item>
    </style>

    <!-- T-3 Text Large — 16/20 -->
    <style name="Text.T3.TextLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/open_sans_bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineHeight">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- T-4 Text Small — 14/20 -->
    <style name="Text.T4.TextSmall" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/open_sans_bold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineHeight">20sp</item>
        <item name="android:letterSpacing">0.00</item>
    </style>

    <!-- L-1 Label — 12/14 -->
    <style name="Text.L1.Label" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/open_sans_bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:lineHeight">14sp</item>
    </style>

    <!-- L-2 Label — 10/12 -->
    <style name="Text.L2.Label" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/open_sans_bold</item>
        <item name="android:textSize">10sp</item>
        <item name="android:lineHeight">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Shape.R16" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="Shape.RoundedFull" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>



    <style name="Settings.Chip.Base" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/selector_options_button_bg</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="chipStrokeColor">@android:color/transparent</item>
        <item name="shapeAppearance">@style/Shape.R16</item>
        <item name="android:textColor">@color/selector_options_button_text</item>
        <item name="chipMinTouchTargetSize">0dp</item>
        <item name="rippleColor">@color/white</item>
    </style>

    <style name="Settings.Chip.Difficulty" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/selector_options_button_bg</item>
        <item name="android:textColor">@color/selector_options_button_text</item>
        <item name="chipIconTint">@color/selector_options_button_ic</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="chipStrokeColor">@android:color/transparent</item>
        <item name="shapeAppearance">@style/Shape.R16</item>
        <item name="android:checkable">true</item>
        <item name="checkedIconVisible">false</item>
        <item name="rippleColor">@color/white</item>
    </style>

    <style name="Settings.Level.Button" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="chipMinHeight">40dp</item>
        <item name="chipCornerRadius">32dp</item>
        <item name="chipBackgroundColor">@color/selector_options_button_bg</item>
        <item name="cardElevation">0dp</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="chipStrokeColor">@android:color/transparent</item>
        <item name="android:textAppearance">@style/Text.T4.TextSmall</item>
        <item name="android:textColor">@color/selector_options_button_text</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipIconVisible">false</item>
        <item name="chipStartPadding">20dp</item>
        <item name="chipEndPadding">20dp</item>
        <item name="rippleColor">@color/white</item>
    </style>

    <style name="Chip.Category" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/selector_options_button_bg</item>
        <item name="chipIconTint">@color/selector_options_button_text</item>
        <item name="android:textColor">@color/selector_options_button_text</item>
        <item name="rippleColor">@color/white</item>
        <item name="shapeAppearance">@style/Shape.RoundedFull</item>
        <item name="chipStrokeColor">@android:color/transparent</item>
        <item name="iconStartPadding">12dp</item>
        <item name="textStartPadding">4dp</item>
        <item name="textEndPadding">12dp</item>
        <item name="android:checkable">true</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipMinHeight">44dp</item>
    </style>

    <style name="button_settings" parent="Text.T3.TextLarge">
            <item name="android:textAllCaps">false</item>
            <item name="singleLine">false</item>
            <item name="android:letterSpacing">0.00</item>
            <item name="cornerRadius">16dp</item>
            <item name="android:textColor">@color/white</item>
            <item name="android:paddingVertical">22dp</item>
            <item name="android:paddingHorizontal">32dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Settings.Card.Difficulty" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/selector_options_button_bg</item>
        <item name="textFillColor">@color/selector_options_button_text</item>
        <item name="iconTint">@color/selector_options_button_ic</item>
        <item name="checkedIcon">@null</item>
        <item name="cardElevation">0dp</item>
        <item name="shapeAppearance">@style/Shape.R16</item>
        <item name="rippleColor">@color/white</item>
    </style>

</resources>